# =============================================================================
# Salesforce → Veza OAA Integration — Environment Configuration Template
# Copy this file to .env and fill in real values.  chmod 600 .env
# =============================================================================

# -----------------------------------------------------------------------------
# Salesforce OAuth 2.0 Client Credentials
# -----------------------------------------------------------------------------

# Salesforce instance URL, e.g. https://myorg.my.salesforce.com
SF_INSTANCE_URL=https://your-org.my.salesforce.com

# OAuth 2.0 token endpoint (Client Credentials grant)
# Typically: https://your-org.my.salesforce.com/services/oauth2/token
SF_TOKEN_URL=https://your-org.my.salesforce.com/services/oauth2/token

# Connected App client ID (Consumer Key in Salesforce Setup)
SF_CLIENT_ID=your_connected_app_client_id_here

# Connected App client secret (Consumer Secret in Salesforce Setup)
SF_CLIENT_SECRET=your_connected_app_client_secret_here

# Salesforce REST API version to use (default: 60.0)
# SF_API_VERSION=60.0

# -----------------------------------------------------------------------------
# Veza Configuration
# -----------------------------------------------------------------------------

# Veza tenant URL, e.g. https://your-company.veza.com
VEZA_URL=https://your-company.veza.com

# Veza API key (generated in Veza UI → Settings → API Keys)
VEZA_API_KEY=your_veza_api_key_here

# -----------------------------------------------------------------------------
# OAA Provider Settings (optional overrides)
# -----------------------------------------------------------------------------

# Provider name as shown in the Veza Access Graph (default: Salesforce)
# PROVIDER_NAME=Salesforce

# Datasource name in Veza (default: derived from SF_INSTANCE_URL hostname)
# DATASOURCE_NAME=myorg.my.salesforce.com
